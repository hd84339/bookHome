<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bookhome</title>
</head>
<body>

    <form action="/listings" method="POST">
        <h2>create a new listing</h2>
        <input type="text" placeholder="enter the title" name="listing[title]">
        <br>
        <br>
        <textarea type="text" placeholder="enter description" name="listing[description]">
        </textarea>
        <br>
        <br>
        <input type="text" placeholder="enter img url" name="listing[image_url]">
        <br>
        <br>
        <input type="number" placeholder="enter the price" name="listing[price]">
        <br>
        <br>
        <input type="text" placeholder="enter location" name="listing[location]">
        <br>
        <br>
        <input type="text" placeholder="enter country" name="listing[country]">
        <button>add</button>
    </form>
    
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Listing</title>
</head>
<body>

    <h3>Listing Details</h3>

    <ul>
        <li><%= listing.title %></li>
        <li><%= listing.description %></li>
        <li>
        <img src="<%= listing.image.url %>" alt="listing image" width="100">
       </li>
        <li>Price: ₹<%= listing.price %></li>
        <li><%= listing.location %>, <%= listing.country %></li>
    </ul>
    <br>

    <a href="/listings/<%= listing._id %>/edit">Edit this Listing</a>
    
</body>
</html>